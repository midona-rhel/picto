{
  "name": "picto",
  "productName": "Picto",
  "private": true,
  "version": "0.1.0-alpha.1",
  "description": "Media library manager",
  "author": "Picto <noreply@picto.app>",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k -n vite,rust,electron -c cyan,red,green \"vite --host 127.0.0.1 --port 8080\" \"cargo watch -w core/src -w native/picto-node/src -s 'cd native/picto-node && ./node_modules/.bin/napi build' -d 1\" \"wait-on tcp:8080 && nodemon --watch native/picto-node/index.node --delay 1 --exec 'electron electron/main.mjs'\"",
    "start:electron": "electron electron/main.mjs",
    "rebuild:native": "cd native/picto-node && ./node_modules/.bin/napi build",
    "build": "tsc && vite build",
    "build:electron": "tsc && vite build",
    "dist:electron": "electron-builder",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "alpha:verify": "npx tsc -p tsconfig.json --noEmit && npm run test -- --run && cargo test --manifest-path core/Cargo.toml --quiet && npm run check:command-parity",
    "alpha:package": "npx electron-builder --publish=never",
    "alpha:smoke": "node ./scripts/ci/alpha-smoke.mjs",
    "gate:alpha": "npm run alpha:verify",
    "gate:legacy": "npm run guard:all",
    "guard:no-native-runtime-imports": "node ./scripts/guard-no-native-runtime-imports.mjs",
    "guard:no-legacy-media": "node ./scripts/guard-no-legacy-media.mjs",
    "guard:no-src-tauri-refs": "node ./scripts/guard-no-src-tauri-refs.mjs",
    "guard:no-raw-colors": "node ./scripts/guard-no-raw-colors.mjs",
    "check:silent-catches": "node ./scripts/check-silent-catches.mjs",
    "guard:grid-architecture": "node ./scripts/ci/check-grid-architecture.mjs",
    "guard:all": "npm run guard:no-native-runtime-imports && npm run guard:no-legacy-media && npm run guard:no-src-tauri-refs && npm run guard:no-raw-colors && npm run check:silent-catches && npm run guard:grid-architecture && npm run check:file-sizes && npm run check:command-parity && npm run check:undo-coverage",
    "check:command-parity": "node ./scripts/check-command-parity.mjs",
    "check:undo-coverage": "node ./scripts/check-undo-coverage.mjs",
    "test:rust": "cargo test --manifest-path core/Cargo.toml",
    "profile:cpu": "bash ./scripts/profile-cpu.sh",
    "check:file-sizes": "node ./scripts/check-file-lengths.mjs"
  },
  "main": "electron/main.mjs",
  "build": {
    "productName": "Picto",
    "appId": "com.picto.desktop",
    "files": [
      "dist/assets/**/*",
      "dist/*.html",
      "electron/**/*",
      "native/picto-node/index.js",
      "native/picto-node/index.node",
      "native/picto-node/index.*.node",
      "!node_modules/**",
      "LICENSE",
      "THIRD_PARTY_LICENSES",
      "package.json"
    ],
    "asarUnpack": [
      "native/**/*.node"
    ],
    "extraFiles": [
      {
        "from": "vendor/ffmpeg/",
        "to": ".",
        "filter": [
          "ffmpeg",
          "ffmpeg.exe",
          "ffprobe",
          "ffprobe.exe"
        ]
      },
      {
        "from": "vendor/gallery-dl/",
        "to": "gallery-dl/",
        "filter": [
          "**/*",
          "!*.whl"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "maintainer": "Picto <noreply@picto.app>",
      "target": [
        "AppImage",
        "deb",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@egjs/react-infinitegrid": "^4.13.0",
    "@mantine/core": "^8.3.14",
    "@mantine/dates": "^8.3.14",
    "@mantine/hooks": "^8.3.14",
    "@mantine/notifications": "^8.3.14",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-virtual": "^3.13.18",
    "blurhash": "^2.0.5",
    "dayjs": "^1.11.19",
    "masonic": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.3.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^24.0.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "^1.18.0",
    "tsx": "^4.20.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.1",
    "wait-on": "^8.0.5"
  }
}
